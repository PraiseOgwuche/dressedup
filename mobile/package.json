    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/three": "^0.185.0",
    "babel-preset-expo": "~54.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
