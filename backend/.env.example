DATABASE_URL=postgresql://postgres:password@localhost:5432/dressedup
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
DEBUG=True
ENV=development
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
RUN_MIGRATIONS_ON_STARTUP=false

# Morning push scheduler (ticks every minute when enabled). Free via Expo Push API.
NOTIFICATION_SCHEDULER_ENABLED=false
# Optional Expo access token for higher push rate limits (not required for dev).
EXPO_ACCESS_TOKEN=

# AI closet ingestion. Leave as "stub" for free, canned results.
# Set to "anthropic" and provide a key to use the real model (costs ~$0.002/scan).
VISION_PROVIDER=stub
ANTHROPIC_API_KEY=
VISION_MODEL=claude-haiku-4-5
